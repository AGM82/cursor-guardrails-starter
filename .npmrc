# Treat peer dependency conflicts as warnings, not hard errors.
# typescript-eslint@8.x declares eslint@^10 as a peer while eslint-plugin-jsx-a11y
# still caps at eslint@^9. Both work correctly together; this flag suppresses the
# conflict that newer npm versions surface as a hard install failure.
legacy-peer-deps=true

# Supply chain: wait 7 days before resolving newly published package versions.
# Newly published packages are a common vector for typosquatting and dependency
# confusion attacks. This gives the community time to detect malicious releases
# before they land in our installs. Required by Semgrep OWASP rule
# npm-missing-minimum-release-age (added in Semgrep v11.10).
min-release-age=7
